---
const title = "Fuel Consumption Calculator";
const description =
  "Figure out MPG, L/100 km, cost-per-trip, and efficiency tips. Includes a modern interactive calculator, formulas, comparisons, real-world driving cases, and a few FAQs.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      :root{
        --bg:#f8fafc;
        --card:#ffffff;
        --text:#0f172a;
        --muted:#475569;
        --line:#e2e8f0;
        --primary:#16a34a;
        --primary-2:#0f766e;
        --soft:#dcfce7;
        --shadow:0 10px 26px rgba(15,23,42,.12);
        --radius:14px;
        --radius-sm:12px;
      }
      *{box-sizing:border-box;}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;background:var(--bg);color:var(--text);}
      .wrap{max-width:960px;margin:22px auto;padding:0 16px 32px;}
      .page-title{display:flex;align-items:center;gap:10px;font-size:22px;font-weight:900;margin:4px 0 8px;color:#0f172a;}
      .page-title .icon{width:38px;height:38px;border-radius:12px;background:linear-gradient(135deg,var(--primary),#4ade80);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900;font-size:20px;}
      .subtitle{margin:0 0 18px;color:var(--muted);line-height:1.5;}

      .card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--line);overflow:hidden;}
      .tabs{display:flex;gap:0;border-bottom:1px solid var(--line);background:#fff;padding:10px 10px 0;overflow-x:auto;}
      .tab{appearance:none;border:1px solid var(--line);border-bottom:none;background:#f8fafc;color:#334155;padding:11px 16px;border-top-left-radius:12px;border-top-right-radius:12px;font-weight:700;cursor:pointer;white-space:nowrap;margin-right:8px;}
      .tab[aria-selected="true"]{background:#fff;color:var(--primary-2);box-shadow:0 -1px 0 #fff inset;}
      .panel{padding:18px;}
      .grid{display:grid;grid-template-columns:1fr;gap:18px;}
      @media (min-width:900px){.grid{grid-template-columns:1.2fr .8fr;}}
      .box{border:1px solid var(--line);border-radius:var(--radius-sm);background:#fff;padding:16px;}
      .box-title{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;gap:10px;}
      .box-title h2{margin:0;font-size:16px;color:#0f172a;}
      .hint{font-size:12px;color:var(--muted);}
      .row{display:flex;gap:14px;flex-wrap:wrap;}
      .field{display:flex;flex-direction:column;gap:6px;flex:1 1 180px;min-width:160px;}
      .field label{font-size:12px;font-weight:700;color:#111827;}
      .input{border:1px solid var(--line);border-radius:10px;padding:10px 12px;font-size:15px;background:#fff;}
      .input:focus{outline:none;border-color:#34d399;box-shadow:0 0 0 3px rgba(52,211,153,.35);}
      .btn{border:1px solid var(--line);border-radius:10px;padding:10px 14px;font-weight:700;background:#fff;color:#0f172a;cursor:pointer;}
      .btn.primary{border-color:#34d399;background:var(--soft);color:#047857;}
      .status{display:inline-flex;align-items:center;padding:6px 12px;border-radius:999px;font-size:12px;font-weight:700;border:1px solid var(--line);background:#eefaf1;color:#047857;}
      .status.wait{background:#fefce8;color:#854d0e;border-color:#fcd34d;}
      .metric{font-size:24px;font-weight:900;margin:6px 0;}
      .metric-note{font-size:12px;color:var(--muted);}
      .foot{margin-top:18px;font-size:13px;color:#475569;display:flex;gap:10px;flex-wrap:wrap;}
      a{color:var(--primary-2);}
      .divider{height:1px;background:var(--line);margin:16px 0;}
      .note{padding:10px 12px;border:1px solid var(--line);border-radius:10px;background:#f8fafc;margin-top:10px;font-size:13px;}
      .recent{margin-top:12px;font-size:13px;color:var(--muted);max-height:140px;overflow:auto;}
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="page-title">
        <div class="icon">⛽</div>
        <div>{title}</div>
      </div>
      <p class="subtitle">Track MPG, L/100 km, km per liter, and the actual fuel cost for your next drive. Includes simple formulas, side-by-side comparisons, real-world use cases, and a few quick FAQ answers for tricky conversions.</p>

      <section class="card" aria-label="Fuel consumption calculator">
        <div class="tabs" role="tablist" aria-label="Sections">
          <button class="tab" type="button" role="tab" aria-selected="true" data-tab="calc">Calculator</button>
          <button class="tab" type="button" role="tab" aria-selected="false" data-tab="formula">Formulas</button>
          <button class="tab" type="button" role="tab" aria-selected="false" data-tab="compare">Reference</button>
          <button class="tab" type="button" role="tab" aria-selected="false" data-tab="cases">Real cases</button>
          <button class="tab" type="button" role="tab" aria-selected="false" data-tab="faq">FAQ</button>
        </div>
        <div class="panel">
          <div data-panel="calc" class="active">
            <div class="grid">
              <div>
                <div class="box">
                  <div class="box-title">
                    <h2>1) Log your trip data</h2>
                    <span class="hint">Turn your odometer + pump info into clean metrics.</span>
                  </div>
                  <div class="row">
                    <div class="field">
                      <label for="distanceValue">Distance covered</label>
                      <input id="distanceValue" class="input" type="number" step="any" placeholder="e.g. 120" />
                    </div>
                    <div class="field">
                      <label for="distanceUnit">Distance unit</label>
                      <select id="distanceUnit" class="input">
                        <option value="miles" selected>Miles</option>
                        <option value="km">Kilometers</option>
                      </select>
                    </div>
                    <div class="field">
                      <label for="fuelValue">Fuel used</label>
                      <input id="fuelValue" class="input" type="number" step="any" placeholder="e.g. 4" />
                    </div>
                    <div class="field">
                      <label for="fuelUnit">Fuel unit</label>
                      <select id="fuelUnit" class="input">
                        <option value="gallon" selected>Gallons</option>
                        <option value="liter">Liters</option>
                      </select>
                    </div>
                    <div class="field">
                      <label for="priceValue">Fuel price</label>
                      <input id="priceValue" class="input" type="number" step="any" placeholder="e.g. 4.50" />
                    </div>
                    <div class="field">
                      <label for="priceUnit">Price per</label>
                      <select id="priceUnit" class="input">
                        <option value="gallon" selected>Per gallon</option>
                        <option value="liter">Per liter</option>
                      </select>
                    </div>
                    <button class="btn" type="button" id="clearBtn">Clear</button>
                  </div>
                  <div class="note">Hint: record your fill-up right after you log the odometer—weapons-grade accuracy beats memorized guesses.</div>
                </div>
              </div>
              <aside class="box" aria-live="polite">
                <div class="box-title">
                  <h2>Results</h2>
                  <span id="statusPill" class="status wait">Waiting</span>
                </div>
                <div>
                  <p class="metric" id="mpgResult">—</p>
                  <p class="metric-note">Miles per gallon (MPG)</p>
                </div>
                <div>
                  <p class="metric" id="lPer100km">—</p>
                  <p class="metric-note">Liters per 100 km</p>
                </div>
                <div>
                  <p class="metric" id="kmPerLiter">—</p>
                  <p class="metric-note">Kilometers per liter</p>
                </div>
                <div>
                  <p class="metric" id="tripCost">—</p>
                  <p class="metric-note">Cost for the trip</p>
                </div>
                <div class="note">Efficiency tip: LPG and diesel drivers often use 10% less fuel than the EPA rating once you normalize for real speed.</div>
              </aside>
            </div>
            <div class="recent" id="recentList">No calculations yet.</div>
          </div>

          <div data-panel="formula">
            <div class="box">
              <div class="box-title">
                <h2>Fuel formulas</h2>
                <span class="hint">Bookmark this for quick sanity checks.</span>
              </div>
              <p class="note"><strong>MPG</strong> = Distance (miles) ÷ Fuel (gallons)</p>
              <p class="note"><strong>L/100km</strong> = (Fuel liters ÷ Distance kilometers) × 100</p>
              <p class="note"><strong>KM per liter</strong> = Distance kilometers ÷ Fuel liters</p>
              <p class="note">Cost per trip = Fuel amount × price per unit (match the units).</p>
            </div>
            <div class="note">Pro tip: If your car’s EPA MPG is 30 and you’re seeing 26, you’re losing ~14% efficiency—check tire pressure and idling time.</div>
          </div>

          <div data-panel="compare">
            <div class="box">
              <div class="box-title">
                <h2>Reference speeds & efficiency</h2>
                <span class="hint">Use these anchors when you judge a product.</span>
              </div>
              <table style="width:100%;border-collapse:collapse;border:1px solid var(--line);font-size:14px;">
                <thead><tr><th style="border:1px solid var(--line);padding:10px;background:#eef2ff;">Typical vehicle</th><th style="border:1px solid var(--line);padding:10px;background:#eef2ff;">EPA MPG</th><th style="border:1px solid var(--line);padding:10px;background:#eef2ff;">L/100 km</th></tr></thead>
                <tbody>
                  <tr><td style="border:1px solid var(--line);padding:10px;">Efficient hybrid</td><td style="border:1px solid var(--line);padding:10px;">50</td><td style="border:1px solid var(--line);padding:10px;">4.7</td></tr>
                  <tr><td style="border:1px solid var(--line);padding:10px;">Crossover SUV</td><td style="border:1px solid var(--line);padding:10px;">27</td><td style="border:1px solid var(--line);padding:10px;">8.7</td></tr>
                  <tr><td style="border:1px solid var(--line);padding:10px;">Full-size truck</td><td style="border:1px solid var(--line);padding:10px;">19</td><td style="border:1px solid var(--line);padding:10px;">12.9</td></tr>
                  <tr><td style="border:1px solid var(--line);padding:10px;">Electric (equivalent)</td><td style="border:1px solid var(--line);padding:10px;">—</td><td style="border:1px solid var(--line);padding:10px;">—</td></tr>
                </tbody>
              </table>
            </div>
            <div class="note">Use these anchors before selling a product: you can promise the numbers, not fantasies.</div>
          </div>

          <div data-panel="cases">
            <div class="box">
              <div class="box-title">
                <h2>Real-world trips</h2>
              </div>
              <ul style="margin:10px 0 0;padding-left:18px;line-height:1.6;">
                <li>San Diego to LA (~120 miles): 4.5 gallons, 26 mpg, ~$20 at $4.45/gal.</li>
                <li>Downtown commute (30 min, 35 miles): 1.7 gallons, 21 mpg, about $7 per day.</li>
                <li>Cross-country (2,400 miles): average 29 mpg, expect $360 in fuel at $4/gal.</li>
              </ul>
              <div class="note">Tracking actual trips helps you explain ROI to customers ("This sedan saved me $80 vs. a truck over 1,200 miles").</div>
            </div>
          </div>

          <div data-panel="faq">
            <div class="box">
              <div class="box-title">
                <h2>FAQ</h2>
              </div>
              <p><strong>Why track cost per trip?</strong><br />It forces you to compare apples-to-apples, especially when gas prices swing daily.</p>
              <p><strong>Is MPG better than L/100km?</strong><br />Depends on the audience. Use MPG for US consumers, L/100km for EU/Asia; the calculator shows both.</p>
              <p><strong>Should I include idle time?</strong><br />Yes—idle shots tank your MPG. Log full trip fuel, not just highway miles.</p>
            </div>
          </div>

          <div class="foot">
            <a href="/">← Back to home</a>
            <span class="hint">Fresh content for the calculator stack</span>
          </div>
        </div>
      </section>
    </main>
    <script>
      const tabs = Array.from(document.querySelectorAll(".tab"));
      const panels = Array.from(document.querySelectorAll("[data-panel]"));
      tabs.forEach(tab => tab.addEventListener("click", () => {
        const name = tab.dataset.tab;
        tabs.forEach(t => t.setAttribute("aria-selected", t === tab ? "true" : "false"));
        panels.forEach(panel => panel.classList.toggle("active", panel.dataset.panel === name));
      }));

      function setPanel(name){
        tabs.forEach(t => t.setAttribute("aria-selected", t.dataset.tab === name ? "true" : "false"));
        panels.forEach(panel => panel.classList.toggle("active", panel.dataset.panel === name));
      }
      setPanel("calc");

      const distanceValue = document.getElementById("distanceValue");
      const distanceUnit = document.getElementById("distanceUnit");
      const fuelValue = document.getElementById("fuelValue");
      const fuelUnit = document.getElementById("fuelUnit");
      const priceValue = document.getElementById("priceValue");
      const priceUnit = document.getElementById("priceUnit");
      const statusPill = document.getElementById("statusPill");
      const mpgResult = document.getElementById("mpgResult");
      const lPer100Km = document.getElementById("lPer100km");
      const kmPerLiter = document.getElementById("kmPerLiter");
      const tripCost = document.getElementById("tripCost");
      const recentList = document.getElementById("recentList");
      const clearBtn = document.getElementById("clearBtn");

      const GALLON_TO_LITER = 3.785411784;
      const MILE_TO_KM = 1.609344;

      function formatMetric(value, decimals=1){
        return Number.isFinite(value) ? value.toFixed(decimals) : "—";
      }

      function updateStatus(isReady){
        if(isReady){
          statusPill.textContent = "Live";
          statusPill.classList.remove("wait");
          statusPill.classList.add("status");
        } else {
          statusPill.textContent = "Waiting";
          statusPill.classList.add("wait");
          statusPill.classList.remove("status");
        }
      }

      function compute(){
        const distance = parseFloat(distanceValue.value);
        const fuel = parseFloat(fuelValue.value);
        const price = parseFloat(priceValue.value);
        if(!distance || !fuel){
          mpgResult.textContent = "—";
          lPer100Km.textContent = "—";
          kmPerLiter.textContent = "—";
          tripCost.textContent = "—";
          recentList.innerHTML = "No calculations yet.";
          updateStatus(false);
          return;
        }

        const distanceMiles = distanceUnit.value === "miles" ? distance : distance / MILE_TO_KM;
        const distanceKm = distanceUnit.value === "km" ? distance : distance * MILE_TO_KM;
        const fuelLiters = fuelUnit.value === "liter" ? fuel : fuel * GALLON_TO_LITER;
        const fuelGallons = fuelLiters / GALLON_TO_LITER;

        const mpg = distanceMiles / fuelGallons;
        const lPer100 = (fuelLiters / distanceKm) * 100;
        const kmPerL = distanceKm / fuelLiters;

        const pricePerLiter = priceUnit.value === "liter" ? price : price / GALLON_TO_LITER;
        const cost = pricePerLiter * fuelLiters;

        mpgResult.textContent = formatMetric(mpg, 1) + " MPG";
        lPer100Km.textContent = formatMetric(lPer100, 2) + " L/100 km";
        kmPerLiter.textContent = formatMetric(kmPerL, 2) + " km/L";
        tripCost.textContent = Number.isFinite(cost) ? "$" + cost.toFixed(2) : "—";
        updateStatus(true);
        pushRecent(`${distance}${distanceUnit.value === "miles" ? "mi" : "km"} / ${fuel}${fuelUnit.value === "gallon" ? "gal" : "L"} → ${formatMetric(mpg,1)} MPG`);
      }

      function pushRecent(text){
        if(!text){return;}
        const entry = document.createElement("div");
        entry.textContent = "• " + text;
        recentList.prepend(entry);
        if(recentList.children.length > 5){
          recentList.removeChild(recentList.lastChild);
        }
      }

      function clearAll(){
        distanceValue.value = "";
        fuelValue.value = "";
        priceValue.value = "";
        mpgResult.textContent = "—";
        lPer100Km.textContent = "—";
        kmPerLiter.textContent = "—";
        tripCost.textContent = "—";
        recentList.textContent = "No calculations yet.";
        updateStatus(false);
      }

      [distanceValue, distanceUnit, fuelValue, fuelUnit, priceValue, priceUnit].forEach(input => input.addEventListener("input", compute));
      clearBtn.addEventListener("click", clearAll);
      updateStatus(false);
    </script>
  </body>
</html>